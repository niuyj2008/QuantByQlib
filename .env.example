# QuantByQlib 环境变量配置模板
# 复制此文件为 .env，填写实际 Key
# cp .env.example .env

# ════════════════════════════════════════════════════════════
#  OpenBB 数据接口 Key（均为免费注册）
# ════════════════════════════════════════════════════════════

# FMP（Financial Modeling Prep）— 基本面数据
# 注册：https://financialmodelingprep.com/register
# 免费限额：250 次/天，30 年历史财务数据
FMP_API_KEY=

# Finnhub — 新闻数据
# 注册：https://finnhub.io/register
# 免费限额：60 次/分钟，无日限额
FINNHUB_API_KEY=

# Alpha Vantage — K 线历史数据（可选，yfinance 可作为免费降级源）
# 注册：https://www.alphavantage.co/support/#api-key
# 免费限额：25 次/天
ALPHA_VANTAGE_API_KEY=

# ════════════════════════════════════════════════════════════
#  RD-Agent 因子发现（可选，仅使用「因子发现」功能时需要）
# ════════════════════════════════════════════════════════════

# DeepSeek API Key
# 注册：https://platform.deepseek.com
# 计费：约 ¥0.001/千 Token input，建议预充 ¥50
DEEPSEEK_API_KEY=

# LLM 模型名称（默认使用 deepseek-chat，性价比最优）
CHAT_MODEL=deepseek/deepseek-chat

# ════════════════════════════════════════════════════════════
#  以下 provider 无需 Key（留空即可）
#  - yfinance：K 线降级源，无需注册
#  - CBOE：期权链，完全免费
#  - FRED：宏观经济数据，完全免费
# ════════════════════════════════════════════════════════════
